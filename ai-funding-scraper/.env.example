# Get your free API key at https://dashboard.exa.ai/api-keys
# Free tier: 1000 searches/month (our scraper uses ~25 per run)
EXA_API_KEY=your_exa_api_key_here

# Apollo.io API key for verified email enrichment
# Get yours at https://app.apollo.io/#/settings/integrations/api_keys
# Without this, emails will be guessed from name+domain patterns
APOLLO_API_KEY=your_apollo_api_key_here
